# EduForge AI - Production Environment Variables
# Copy this file to .env and fill in your values

# Supabase PostgreSQL Connection
# Get this from: Supabase > Settings > Database > Connection string
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres

# OpenAI API Key
# Get this from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-api-key

# OpenAI Model (optional, defaults to gpt-4-turbo-preview)
OPENAI_MODEL=gpt-4-turbo-preview

# Security Secret (generate a random 32+ character string)
# Generate with: openssl rand -base64 32
SECRET_KEY=your-super-secret-key-change-this-in-production
